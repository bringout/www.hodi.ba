---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="bs">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="hero">
			<img src="/logo.svg" alt="Hodi!" class="hero-logo" />
			<p>Dobrodošli!</p>
		</main>
		<style>
			.hero {
				text-align: center;
				padding: 4em 1em;
			}
			.hero-logo {
				max-width: 320px;
				width: 100%;
				height: auto;
				margin-bottom: 1em;
			}
			.hero p {
				font-size: 1.4em;
				color: rgb(var(--gray));
			}
		</style>
		<Footer />
	</body>
</html>
